name: Release C# SDK

on:
  workflow_dispatch:

jobs:
  preview-and-validate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Fern CLI
        uses: fern-api/setup-fern-cli@v1

      - name: Generate preview
        env:
          FERN_TOKEN: ${{ secrets.FERN_TOKEN }}
        run: fern generate --group csharp-sdk --preview --output ./preview --log-level debug

      - name: Set up .NET
        uses: actions/setup-dotnet@v4
        with:
          dotnet-version: "9.0.x"

      # Adapt the build/test commands to match your generated SDK's toolchain
      - name: Build
        working-directory: ./preview/fernapi-fern-csharp-sdk  # adjust to match generator name
        run: dotnet build

      - name: Test
        working-directory: ./preview/fernapi-fern-csharp-sdk
        run: dotnet test

  release:
    needs: preview-and-validate
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Fern CLI
        uses: fern-api/setup-fern-cli@v1

      - name: Generate C# SDK
        env:
          FERN_TOKEN: ${{ secrets.FERN_TOKEN }}
        run: fern generate --group csharp-sdk --log-level debug --version AUTO
