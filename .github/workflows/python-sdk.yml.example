name: Release Python SDK

on:
  push:
    branches:
      - main
    paths:
      - "fern/openapi.yml"
      - "fern/openapi-overlay.yml"
      - "fern/fern.config.json"
      - "fern/generators.yml"
  pull_request:
    paths:
      - "fern/openapi.yml"
      - "fern/openapi-overlay.yml"
      - "fern/fern.config.json"
      - "fern/generators.yml"
  workflow_dispatch:

jobs:
  preview-and-validate:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Fern CLI
        uses: fern-api/setup-fern-cli@v1

      - name: Generate preview
        env:
          FERN_TOKEN: ${{ secrets.FERN_TOKEN }}
        run: fern generate --group python-sdk --preview --output ./preview --log-level debug

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      # Adapt the install/build/test commands to match your generated SDK's toolchain
      - name: Install dependencies
        working-directory: ./preview/fernapi-fern-python-sdk  # adjust to match generator name
        run: |
          pip install poetry
          poetry install

      - name: Build
        working-directory: ./preview/fernapi-fern-python-sdk
        run: poetry build

      - name: Test
        working-directory: ./preview/fernapi-fern-python-sdk
        run: poetry run pytest

  release:
    needs: preview-and-validate
    if: github.event_name == 'push' || github.event_name == 'workflow_dispatch'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repo
        uses: actions/checkout@v4

      - name: Setup Fern CLI
        uses: fern-api/setup-fern-cli@v1

      - name: Generate Python SDK
        env:
          FERN_TOKEN: ${{ secrets.FERN_TOKEN }}
        run: fern generate --group python-sdk --log-level debug --version AUTO
